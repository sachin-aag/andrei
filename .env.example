# Auth.js (NextAuth v5) — required for authentication
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
# Your Resend API key (from resend.com)
AUTH_RESEND_KEY=
# The "from" address for magic link emails (must match your verified Resend domain)
AUTH_EMAIL_FROM=noreply@andreihealth.com
# Your app URL — auto-detected on Vercel, set explicitly for local dev / CI
# AUTH_URL=http://localhost:3000
# Trust Host header when not on Vercel (Docker, Playwright on 127.0.0.1, etc.)
# AUTH_TRUST_HOST=true

# Playwright e2e only — never set on production deployments
# ALLOW_TEST_LOGIN=true
# TEST_AUTH_EMAIL=test.engineer@mjbiopharm.com

# Neon Postgres (Vercel Marketplace)
# Full pooled connection string from the Neon dashboard.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require&channel_binding=require

# Google Gemini API key (optional — used directly by @ai-sdk/google when set).
# Get one from https://aistudio.google.com/app/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key-here

# Vercel AI Gateway (recommended on Vercel — also used for DOCX formula extraction).
# Enable in the project dashboard, then add this key to Production *and* Preview:
# https://vercel.com/dashboard/ai-gateway
AI_GATEWAY_API_KEY=

# Criteria review (stored in Neon; see docs/criteria-review.md)
# CRITERIA_REVIEW_MANAGERS_ONLY=true
# CRITERIA_REVIEW_DISABLED=true
