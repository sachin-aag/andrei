# Auth.js (NextAuth v5) — required for authentication
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
# Your Resend API key (from resend.com)
AUTH_RESEND_KEY=
# The "from" address for magic link emails (must match your verified Resend domain)
AUTH_EMAIL_FROM=noreply@andreihealth.com
# Your app URL — auto-detected on Vercel, set explicitly for local dev / CI
# AUTH_URL=http://localhost:3000
# Trust Host header when not on Vercel (Docker, Playwright on 127.0.0.1, etc.)
# AUTH_TRUST_HOST=true

# Playwright e2e only — never set on production deployments
# ALLOW_TEST_LOGIN=true
# TEST_AUTH_EMAIL=test.engineer@mjbiopharm.com

# Database (one URL per environment — see docs/database-environments.md)
#
# Local Docker (no Neon admin): npm run db:local:up && npm run db:push
# DATABASE_URL=postgresql://andrei:andrei@localhost:5432/andrei_dev
#
# Neon — production/main branch (Vercel Production only)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require
#
# Neon — dev branch (localhost + Vercel Preview/Development)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST-dev.neon.tech/DBNAME?sslmode=require
DATABASE_URL=postgresql://andrei:andrei@localhost:5432/andrei_dev

# Google Gemini API key (optional — used when Vertex/WIF and Gateway are not selected).
# Get one from https://aistudio.google.com/app/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key-here

# Vercel AI Gateway (DOCX math extraction, etc.). Criteria eval uses Vertex when
# GOOGLE_VERTEX_PROJECT is set — not Gateway (free tier blocks gemini-3.1-flash-lite).
# https://vercel.com/dashboard/ai-gateway
AI_GATEWAY_API_KEY=

# Production + local eval (Vertex). On Vercel: WIF via GCP_WIF_* + OIDC.
# Local: `gcloud auth application-default login`, or set GOOGLE_GENERATIVE_AI_API_KEY instead.
# GOOGLE_VERTEX_PROJECT=your-gcp-project
# GOOGLE_VERTEX_LOCATION=us-central1
# GCP_WIF_AUDIENCE=...
# GCP_SERVICE_ACCOUNT_EMAIL=...

# Langfuse observability (https://cloud.langfuse.com → Settings → API Keys)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Criteria review (stored in Neon; see docs/criteria-review.md)
# CRITERIA_REVIEW_MANAGERS_ONLY=true
# CRITERIA_REVIEW_DISABLED=true
