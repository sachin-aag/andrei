# Optional: require this shared password before any page (middleware → /unlock).
# Leave unset locally to skip the gate. Set on Vercel for a simple site lock.
# SITE_ACCESS_PASSWORD=

# Neon Postgres (Vercel Marketplace)
# Full pooled connection string from the Neon dashboard.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require&channel_binding=require

# Google Gemini API key (used directly by @ai-sdk/google).
# Get one from https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key-here

# Optional: if you'd rather route through the Vercel AI Gateway,
# set AI_GATEWAY_API_KEY instead (https://vercel.com/dashboard/ai-gateway).
# AI_GATEWAY_API_KEY=

# Google Vertex (offline bulk eval only — scripts/eval, src/lib/eval)
# Auth: Application Default Credentials (recommended locally: `gcloud auth application-default login`)
# GOOGLE_VERTEX_PROJECT=your-gcp-project-id
# Gemini on Vertex (default us-central1):
# GOOGLE_VERTEX_LOCATION=us-central1
# Claude on Vertex (default us-east5 — override if your model is in another region):
# GOOGLE_VERTEX_ANTHROPIC_LOCATION=us-east5

# OpenAI (offline bulk eval only)
# OPENAI_API_KEY=

# Criteria review (stored in Neon; see docs/criteria-review.md)
# CRITERIA_REVIEW_MANAGERS_ONLY=true
# CRITERIA_REVIEW_DISABLED=true
