    "causal_chain": {
      "methodology": "Five Why",
      "steps": [
        {
          "step_number": 1,
          "why_question": "Why was the temperature data not recorded/captured in the Intermediate Walk-in Cold Room system software (Kyoshi application)?",
          "answer": "Communication failure occurred between the Cold Room HMI and the Kyoshi application.",
          "is_root_cause": false
        },
        {
          "step_number": 2,
          "why_question": "Why did the communication failure occur?",
          "answer": "The date and time on the Cold Room HMI were out of synchronization with the current date and time, triggering communication failure alarms and disrupting data logging.",
          "is_root_cause": false
        },
        {
          "step_number": 3,
          "why_question": "Why was the date/time out of synchronization with the current date and time on the HMI?",
          "answer": "The HMI uses coin-cell batteries to maintain the RTC and SRAM during power interruptions; extended power-off periods accelerated battery discharge, and battery degradation/defects or manufacturing quality issues may have contributed to premature failure.",
          "is_root_cause": true
        },
        {
          "step_number": 4,
          "why_question": "WHY: Not Applicable",
          "answer": "Not Applicable",
          "is_root_cause": false
        },
        {
          "step_number": 5,
          "why_question": "WHY: Not Applicable",
          "answer": "Not Applicable",
          "is_root_cause": false
        }
      ],
      "conclusion": "The data loss was caused by HMI time synchronization loss, driven by battery discharge/failure during prolonged power-off conditions, which led to communication failure with the Kyoshi application."
    },
    "root_cause_classification": [
      {
        "level_1": "Equipment / Instrument",
