    "causal_chain": {
      "methodology": "5-Why",
      "steps": [
        {
          "step_number": 1,
          "why_question": "Why did the Drug Product new employee take Drug substance orientation?",
          "answer": "Because HR forwarded the drug product employees to the drug substance warehouse colleague for orientation training.",
          "is_root_cause": false
        },
        {
          "step_number": 2,
          "why_question": "Why did HR forward drug product employees to a drug substance person for orientation training?",
          "answer": "Because the HR colleague was confused between drug substance employees and drug product employees.",
          "is_root_cause": false
        },
        {
          "step_number": 3,
          "why_question": "Why was the HR colleague confused?",
          "answer": "Because 14 employees joined in one campaign, making it difficult to identify which employees belonged to which department.",
          "is_root_cause": false
        },
        {
          "step_number": 4,
          "why_question": "Why were the employees considered to be from drug substance unit?",
          "answer": "Because yellow-colored files for drug substance and yellow professional-document files were in front of the HR colleague, leading to misidentification of the drug product employees as drug substance employees.",
          "is_root_cause": true
        }
      ],
      "conclusion": "The root cause was human performance—an omission/error due to confusion caused by similar yellow file appearance and unclear responsibility boundaries, leading to misrouting of drug product employees for drug substance orientation."
    },
