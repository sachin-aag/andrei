    "causal_chain": {
      "methodology": "5-Why",
      "steps": [
        {
          "step_number": 1,
          "why_question": "Why was the PPT for Corporate Communication not as per approved format SOP/DP/QA/033/F01-R00?",
          "answer": "Because the HR colleague missed entering the company name on the first page and used an incorrect date format while preparing the PPT.",
          "is_root_cause": false
        },
        {
          "step_number": 2,
          "why_question": "Why were all activities for the PPT performed on the last day of the month?",
          "answer": "Because the training was due in August 2023 and 31/08/2023 was the last day to authorize the PPT before conducting the training.",
          "is_root_cause": false
        },
        {
          "step_number": 3,
          "why_question": "Why were the training activities not pre-planned to complete earlier?",
          "answer": "Because the training was planned for 31/08/2023 and the PPT had to be ready before the training time, but it was not authorized due to format noncompliance.",
          "is_root_cause": false
        }
      ],
      "conclusion": "The causal chain identifies human performance/omission during PPT preparation, driven by late execution on the last day and insufficient verification of the approved format, as the root cause."
    },
