        "sop_number": "SOP/DP/QA/002/R02",
        "title": "Good Documentation Practices",
        "clause_number": "7.8.7.2",
        "requirement_text": "Corrections shall be made along with sign and date in the document.",
        "role": "violated_requirement"
      },
      {
        "sop_number": "SOP/DP/QA/003/R03",
        "title": "Document and Data Control",
        "clause_number": "7.15",
        "requirement_text": "Before submitting any routine document for destruction, the user department shall strike out each page with sign and date, enter details in the document destruction logbook, and QA shall verify the documents against the logbook entry.",
