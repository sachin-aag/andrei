    "causal_chain": {
      "methodology": "Five Why",
      "steps": [
        {
          "step_number": 1,
          "why_question": "Why was the signed document from the drug substance unit found in a strikeout condition at the drug product unit?",
          "answer": "Because the Retest and Expiry Material Checklist prepared by the DS warehouse colleague was forwarded to the DP facility for checking and signing by the warehouse head.",
          "is_root_cause": false
        },
        {
          "step_number": 2,
          "why_question": "Why was the DS unit document forwarded to the DP facility for checking and signing?",
          "answer": "Because the warehouse head is responsible for both DS and DP units and is stationed in the DP facility warehouse area.",
          "is_root_cause": false
        },
        {
          "step_number": 3,
          "why_question": "Why was the signed document strikeout and used as rough?",
          "answer": "Because the first signed checklist was identified as the incorrect document after signing, so it was strikeout and left in the warehouse office; blank pages were then used as rough pages.",
          "is_root_cause": false
        },
        {
          "step_number": 4,
          "why_question": "Why were the strikeout documents not destroyed?",
          "answer": "Because the warehouse head failed to destroy the documents as required by the approved procedure after correction.",
          "is_root_cause": true
        },
        {
          "step_number": 5,
          "why_question": "Why were other documents kept in the warehouse area?",
          "answer": "Because the gross-weight verification documents were carried to the DP plant by the HOD and were not returned to the DS team until the nonconformance was identified.",
          "is_root_cause": false
        }
      ],
      "conclusion": "The root cause was an omission by the warehouse head: strikeout/rough documents were not destroyed and controlled return/logging between DS and DP was not completed, reflecting ineffective responsibility boundaries."
    },
    "root_cause_classification": [
      {
        "level_1": "Human error",
        "level_2": "Omission error",
        "level_3": "Responsibility boundaries ineffective"
      }
    ],
