    "causal_chain": {
      "methodology": "Five Why",
      "steps": [
        {
          "step_number": 1,
          "why_question": "Why was the cycle aborted manually in heat up phase?",
          "answer": "Because the cycle remained stuck in the heat-up phase for approximately 1 hour and 24 minutes.",
          "is_root_cause": false
        },
        {
          "step_number": 2,
          "why_question": "Why did the cycle remain stuck in the heat up phase for 1 hour and 24 minutes?",
          "answer": "Because drain sensor T1 did not reach the required sterilization temperature of 121.1°C.",
          "is_root_cause": false
        },
        {
          "step_number": 3,
          "why_question": "Why did drain sensor T1 not reach the required temperature?",
          "answer": "Because chamber pressure was low, with maximum observed pressure of 0.252 bar.",
          "is_root_cause": false
        },
        {
          "step_number": 4,
          "why_question": "Why was the chamber pressure low?",
          "answer": "Because incoming pure steam to the chamber stopped.",
          "is_root_cause": false
        },
        {
          "step_number": 5,
          "why_question": "Why did incoming pure steam stop?",
          "answer": "Because other chamber sensors reached sterilization temperature, causing control logic to stop pure steam supply despite low chamber pressure.",
          "is_root_cause": false
        },
        {
          "step_number": 6,
          "why_question": "Why did all other chamber sensors reach sterilization temperature despite low chamber pressure?",
          "answer": "Because jacket pressure increased up to 2.8 bar, influencing chamber temperature readings.",
          "is_root_cause": false
        },
        {
          "step_number": 7,
          "why_question": "Why did jacket pressure increase up to 2.8 bar?",
          "answer": "Because raw steam was continuously entering the jacket.",
          "is_root_cause": false
        },
        {
          "step_number": 8,
          "why_question": "Why was raw steam continuously entering the jacket?",
          "answer": "Because the jacket steam inlet valve (Valve 101) was malfunctioning.",
          "is_root_cause": true
        }
      ],
      "conclusion": "The most probable root cause was malfunction of jacket steam inlet valve (Valve 101), allowing continuous raw steam entry into the jacket and causing abnormal jacket pressure and apparent temperature overshoot."
    },
    "root_cause_classification": [
      {
        "level_1": "Equipment/Instrument",
        "level_2": "Mechanical failure",
        "level_3": "Not Applicable"
      }
    ],
