    "causal_chain": {
      "methodology": "5-Why",
      "steps": [
        {
          "step_number": 1,
          "why_question": "Why was the Wavelength Accuracy test found out of calibration (OOC)?",
          "answer": "Because the minimum absorbance was obtained at 242 nm, outside the SOP acceptance criteria of 243–247 nm.",
          "is_root_cause": false
        },
        {
          "step_number": 2,
          "why_question": "Why was the minimum absorbance obtained at 242 nm?",
          "answer": "Because a drop in HPLC system pressure caused inaccurate area response of the wavelength accuracy standard solution.",
          "is_root_cause": false
        },
        {
          "step_number": 3,
          "why_question": "Why did the HPLC system pressure drop?",
          "answer": "Most probably because an air bubble was trapped in the pump, specifically stuck in the check-inlet tubing.",
          "is_root_cause": true
        }
      ],
      "conclusion": "The nonconformance was caused by instrument error due to an air bubble trapped in the pump/check-inlet tubing, leading to pressure drop and an erroneous wavelength accuracy result."
    },
    "root_cause_classification": [
      {
        "level_1": "Instrument error",
        "level_2": "Mechanical Failure",
        "level_3": "Air bubble trapped in pump/check-inlet tubing causing pressure drop"
      }
    ],
